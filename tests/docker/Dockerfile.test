# Minimal clean-room test image — simulates a fresh install with no pre-installed tooling.
# Build args:
#   PYTHON_VERSION — e.g. "3.9", "3.12" (default 3.11)
#   INSTALL_GITLEAKS — "true" or "false" (default false)

ARG PYTHON_VERSION=3.11
FROM python:${PYTHON_VERSION}-slim

ARG INSTALL_GITLEAKS=false
ENV INSTALL_GITLEAKS=${INSTALL_GITLEAKS}

# Install system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Optionally install gitleaks
RUN if [ "$INSTALL_GITLEAKS" = "true" ]; then \
      wget -q https://github.com/gitleaks/gitleaks/releases/download/v8.21.2/gitleaks_8.21.2_linux_x64.tar.gz -O /tmp/gl.tgz \
      && tar -xzf /tmp/gl.tgz -C /usr/local/bin gitleaks \
      && chmod +x /usr/local/bin/gitleaks \
      && rm /tmp/gl.tgz; \
    fi

# Install pytest
RUN pip install --no-cache-dir pytest

WORKDIR /leak-guard

# Copy only plugin source and tests (simulates fresh install, no dev artifacts)
COPY plugins/ plugins/
COPY tests/ tests/

# The smoke payload is assembled at runtime from two halves so it is never
# stored as a literal credential string in the image layer or source file.
CMD ["bash", "-c", \
     "echo '=== selftest ===' && python3 plugins/leak-guard/hooks/scanner.py selftest && \
      echo '=== pytest ===' && pytest tests/test_scanner.py -v && \
      echo '=== smoke ===' && \
      HALF1='CSKC:Scds' && HALF2='JCCKL-SLKDKLCNLKCEIN-K2233as' && \
      PAYLOAD=\"{\\\"hook_event_name\\\":\\\"UserPromptSubmit\\\",\\\"prompt\\\":\\\"key ${HALF1}${HALF2}\\\",\\\"session_id\\\":\\\"docker\\\"}\" && \
      OUTPUT=$(echo \"$PAYLOAD\" | python3 plugins/leak-guard/hooks/scanner.py hook-user-prompt) && \
      echo \"$OUTPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); ctx=d['hookSpecificOutput']['additionalContext']; assert 'leak-guard' in ctx and '[REDACTED]' in ctx, f'smoke failed: {ctx[:200]}'\" && \
      echo 'All checks passed'"]
