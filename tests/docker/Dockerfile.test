# Minimal clean-room test image — simulates a fresh install with no pre-installed tooling.
# Build args:
#   PYTHON_VERSION — e.g. "3.9", "3.12" (default 3.11)
#   INSTALL_GITLEAKS — "true" or "false" (default false)

ARG PYTHON_VERSION=3.11
FROM python:${PYTHON_VERSION}-slim

ARG INSTALL_GITLEAKS=false
ENV INSTALL_GITLEAKS=${INSTALL_GITLEAKS}

# Install system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Optionally install gitleaks (detect arch for ARM/x64 compatibility)
RUN if [ "$INSTALL_GITLEAKS" = "true" ]; then \
      ARCH=$(dpkg --print-architecture) && \
      if [ "$ARCH" = "arm64" ] || [ "$ARCH" = "aarch64" ]; then \
        GL_ARCH="arm64"; \
      else \
        GL_ARCH="x64"; \
      fi && \
      wget -q "https://github.com/gitleaks/gitleaks/releases/download/v8.21.2/gitleaks_8.21.2_linux_${GL_ARCH}.tar.gz" -O /tmp/gl.tgz \
      && tar -xzf /tmp/gl.tgz -C /usr/local/bin gitleaks \
      && chmod +x /usr/local/bin/gitleaks \
      && rm /tmp/gl.tgz; \
    fi

# Install pytest
RUN pip install --no-cache-dir pytest

WORKDIR /leak-guard

# Copy only plugin source and tests (simulates fresh install, no dev artifacts)
COPY plugins/ plugins/
COPY tests/ tests/

# Smoke tests:
#   1. selftest — internal checks (Python, rules, gitleaks, hooks)
#   2. pytest — unit + integration test suite
#   3. pre-tool smoke — Bash input with fake AWS key is denied
#   4. post-tool smoke — Bash output with fake AWS key is blocked
#   5. filename smoke — Read of .env is denied
#
# Credentials assembled at runtime from halves to avoid literal patterns in layers.
CMD ["bash", "-c", \
     "echo '=== selftest ===' && python3 plugins/leak-guard/hooks/scanner.py selftest && \
      echo '=== pytest ===' && pytest tests/test_scanner.py tests/test_integration.py -v && \
      echo '=== pre-tool smoke ===' && \
      HALF1='AKIAY3FDSN' && HALF2='DKFKSIDJSW' && \
      PAYLOAD=\"{\\\"hook_event_name\\\":\\\"PreToolUse\\\",\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"echo ${HALF1}${HALF2}\\\"}}\" && \
      OUTPUT=$(echo \"$PAYLOAD\" | python3 plugins/leak-guard/hooks/scanner.py hook-pre-tool) && \
      echo \"$OUTPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); assert d['hookSpecificOutput']['permissionDecision']=='deny', 'pre-tool smoke failed'\" && \
      echo 'pre-tool smoke OK' && \
      echo '=== post-tool smoke ===' && \
      PAYLOAD2=\"{\\\"hook_event_name\\\":\\\"PostToolUse\\\",\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"custom-cmd\\\"},\\\"tool_response\\\":{\\\"stdout\\\":\\\"key=${HALF1}${HALF2}\\\"}}\" && \
      OUTPUT2=$(echo \"$PAYLOAD2\" | python3 plugins/leak-guard/hooks/scanner.py hook-post-tool) && \
      echo \"$OUTPUT2\" | python3 -c \"import sys,json; d=json.load(sys.stdin); assert d['decision']=='block', 'post-tool smoke failed'\" && \
      echo 'post-tool smoke OK' && \
      echo '=== filename smoke ===' && \
      PAYLOAD3=\"{\\\"hook_event_name\\\":\\\"PreToolUse\\\",\\\"tool_name\\\":\\\"Read\\\",\\\"tool_input\\\":{\\\"file_path\\\":\\\"/home/user/.env\\\"}}\" && \
      OUTPUT3=$(echo \"$PAYLOAD3\" | python3 plugins/leak-guard/hooks/scanner.py hook-pre-tool) && \
      echo \"$OUTPUT3\" | python3 -c \"import sys,json; d=json.load(sys.stdin); assert d['hookSpecificOutput']['permissionDecision']=='deny', 'filename smoke failed'\" && \
      echo 'filename smoke OK' && \
      echo 'All checks passed'"]
